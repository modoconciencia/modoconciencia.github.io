---
---

<section class="relative z-10 px-6 pb-20 md:pb-24">

    <div class="max-w-7xl mx-auto">

        <!-- Title -->
        <div class="flex items-center justify-center gap-3 md:gap-4 mb-10 md:mb-14">

            <div class="w-8 md:w-12 h-px bg-[#C9A24A]/40"></div>

            <h2 class="text-[#C9A24A] text-xl md:text-2xl font-semibold tracking-tight text-center">
                Proyectos destacados
            </h2>

            <div class="w-8 md:w-12 h-px bg-[#C9A24A]/40"></div>

        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

            <!-- SPOTIFY -->
            <div class="group rounded-3xl overflow-hidden border border-white/5 bg-[#111111]/70 backdrop-blur-xl transition-all duration-300 hover:border-[#C9A24A]/20 hover:-translate-y-1">

                <div class="relative h-56 overflow-hidden">

                    <a
                        href="https://open.spotify.com/user/316klomwzc4wfwro5ptakelsmzsy"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block w-full h-full"
                    >

                        <img
                            src="/projects/spotify.jpg"
                            alt="Spotify"
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                        />

                        <div class="absolute inset-0 bg-black/10"></div>

                    </a>

                </div>

                <div class="p-6 md:p-7">

                    <h3 class="text-[#f5f7fa] text-xl font-semibold mb-3">
                        SPOTIFY
                    </h3>

                    <p class="text-[#6e7178] text-sm leading-relaxed mb-6">
                        Música y proyectos creativos de Modo Conciencia Studio para el despertar de la conciencia.
                    </p>

                    <a
                        href="https://open.spotify.com/user/316klomwzc4wfwro5ptakelsmzsy"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center text-[#C9A24A] text-sm font-medium transition-all duration-300 hover:text-[#F1C85B]"
                    >
                        Escuchar ahora
                    </a>

                </div>

            </div>

            <!-- TELEGRAM -->
            <div class="group rounded-3xl overflow-hidden border border-white/5 bg-[#111111]/70 backdrop-blur-xl transition-all duration-300 hover:border-[#C9A24A]/20 hover:-translate-y-1">

                <div class="relative h-56 overflow-hidden">

                    <a
                        href="https://t.me/modoconciencia"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block w-full h-full"
                    >

                        <img
                            src="/projects/telegram.jpg"
                            alt="Telegram"
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                        />

                        <div class="absolute inset-0 bg-black/10"></div>

                    </a>

                </div>

                <div class="p-6 md:p-7">

                    <h3 class="text-[#f5f7fa] text-xl font-semibold mb-3">
                        TELEGRAM
                    </h3>

                    <p class="text-[#6e7178] text-sm leading-relaxed mb-6">
                        Canal de comunicación y comunidad digital para compartir contenido, ideas y actualizaciones.
                    </p>

                    <a
                        href="https://t.me/modoconciencia"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center text-[#C9A24A] text-sm font-medium transition-all duration-300 hover:text-[#F1C85B]"
                    >
                        Acceder al canal
                    </a>

                </div>

            </div>

            <!-- TIKTOK -->
            <div class="group rounded-3xl overflow-hidden border border-white/5 bg-[#111111]/70 backdrop-blur-xl transition-all duration-300 hover:border-[#C9A24A]/20 hover:-translate-y-1">

                <div class="relative h-56 overflow-hidden">

                    <a
                        href="https://www.tiktok.com/@modoconciencia"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block w-full h-full"
                    >

                        <img
                            src="/projects/tiktok.jpg"
                            alt="TikTok"
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                        />

                        <div class="absolute inset-0 bg-black/10"></div>

                    </a>

                </div>

                <div class="p-6 md:p-7">

                    <h3 class="text-[#f5f7fa] text-xl font-semibold mb-3">
                        TIKTOK
                    </h3>

                    <p class="text-[#6e7178] text-sm leading-relaxed mb-6">
                        Reflexiones sobre conocimiento, desarrollo personal, conciencia y crecimiento consciente.
                    </p>

                    <a
                        href="https://www.tiktok.com/@modoconciencia"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center text-[#C9A24A] text-sm font-medium transition-all duration-300 hover:text-[#F1C85B]"
                    >
                        Acceder al perfil
                    </a>

                </div>

            </div>

        </div>

    </div>

</section>

