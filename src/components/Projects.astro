---
---

<section class="relative z-10 px-6 pb-20 md:pb-24">

    <div class="max-w-7xl mx-auto">

        <!-- Title -->
        <div class="flex items-center justify-center gap-3 md:gap-4 mb-10 md:mb-14">

            <div class="w-8 md:w-12 h-px bg-[#cbb190]/30"></div>

            <h2 class="text-[#ddceb9] text-xl md:text-2xl font-semibold tracking-tight text-center">
                Proyectos destacados
            </h2>

            <div class="w-8 md:w-12 h-px bg-[#cbb190]/30"></div>

        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

            <!-- Proyecto 1 -->
            <div class="group rounded-3xl overflow-hidden border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl transition-all duration-300 hover:border-[#cbb190]/20 hover:-translate-y-1">

                <!-- Image -->
                <div class="relative h-56 overflow-hidden">

                    <img
                        src="/projects/portfolio.jpg"
                        alt="Portafolio Personal"
                        class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                    />

                    <div class="absolute inset-0 bg-black/10"></div>

                </div>

                <!-- Content -->
                <div class="p-6 md:p-7">

                    <h3 class="text-[#f5f7fa] text-xl font-semibold mb-3">
                        PERSONAL PORTFOLIO
                    </h3>

                    <p class="text-[#6e7178] text-sm leading-relaxed mb-6">
                        Espacio personal donde desarrollo y experimento nuevas ideas, diseños web y sistemas digitales.
                    </p>

                    <a
                        href="#"
                        class="inline-flex items-center text-[#cbb190] text-sm font-medium transition-all duration-300 hover:text-[#ddceb9]"
                    >
                        Ver proyectos →
                    </a>

                </div>

            </div>

            <!-- Proyecto 2 -->
            <div class="group rounded-3xl overflow-hidden border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl transition-all duration-300 hover:border-[#cbb190]/20 hover:-translate-y-1">

                <!-- Image -->
                <div class="relative h-56 overflow-hidden">

                    <img
                        src="/projects/youtube.jpg"
                        alt="Modo Conciencia YouTube"
                        class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                    />

                    <div class="absolute inset-0 bg-black/10"></div>

                </div>

                <!-- Content -->
                <div class="p-6 md:p-7">

                    <h3 class="text-[#f5f7fa] text-xl font-semibold mb-3">
                        YOUTUBE
                    </h3>

                    <p class="text-[#6e7178] text-sm leading-relaxed mb-6">
                        Modo Conciencia | Contenido enfocado en reflexión, el conocimiento y la expansión de la conciencia.
                    </p>

                    <a
                        href="https://www.youtube.com/@modoconcienciaYT"
                        target="_blank"
                        class="inline-flex items-center text-[#cbb190] text-sm font-medium transition-all duration-300 hover:text-[#ddceb9]"
                    >
                        Ir al canal →
                    </a>

                </div>

            </div>

            <!-- Proyecto 3 -->
            <div class="group rounded-3xl overflow-hidden border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl transition-all duration-300 hover:border-[#cbb190]/20 hover:-translate-y-1">

                <!-- Image -->
                <div class="relative h-56 overflow-hidden">

                    <img
                        src="/projects/telegram.jpg"
                        alt="Modo Conciencia Telegram"
                        class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                    />

                    <div class="absolute inset-0 bg-black/10"></div>

                </div>

                <!-- Content -->
                <div class="p-6 md:p-7">

                    <h3 class="text-[#f5f7fa] text-xl font-semibold mb-3">
                        TELEGRAM
                    </h3>

                    <p class="text-[#6e7178] text-sm leading-relaxed mb-6">
                        Canal de comunicación y comunidad digital para compartir contenido, ideas y actualizaciones.
                    </p>

                    <a
                        href="https://t.me/modoconciencia"
                        target="_blank"
                        class="inline-flex items-center text-[#cbb190] text-sm font-medium transition-all duration-300 hover:text-[#ddceb9]"
                    >
                        Unirse al canal →
                    </a>

                </div>

            </div>

        </div>

    </div>

</section>