---
---

<section class="relative z-10 px-6 pb-20 md:pb-24">

    <div class="max-w-7xl mx-auto">

        <!-- Tecnologías & Herramientas -->
        <div>

            <div class="flex items-center justify-center gap-3 md:gap-4 mb-8 md:mb-10">

                <div class="w-8 md:w-12 h-px bg-[#cbb190]/30"></div>

                <h2 class="text-[#ddceb9] text-xl md:text-2xl font-semibold tracking-tight text-center">
                    Tecnologías utilizadas
                </h2>

                <div class="w-8 md:w-12 h-px bg-[#cbb190]/30"></div>

            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-8 gap-4 md:gap-5">

                <!-- HTML -->
                <div class="rounded-2xl border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl p-5 md:p-6 flex flex-col items-center justify-center text-center transition-all duration-300 hover:border-[#cbb190]/30 hover:-translate-y-1">

                    <img
                        src="/tech/html.png"
                        alt="HTML5"
                        class="w-10 h-10 md:w-14 md:h-14 object-contain mb-3 md:mb-4"
                    />

                    <h3 class="text-[#f5f7fa] text-sm md:text-base font-medium">
                        HTML5
                    </h3>

                </div>

                <!-- CSS -->
                <div class="rounded-2xl border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl p-5 md:p-6 flex flex-col items-center justify-center text-center transition-all duration-300 hover:border-[#cbb190]/30 hover:-translate-y-1">

                    <img
                        src="/tech/css.png"
                        alt="CSS3"
                        class="w-10 h-10 md:w-14 md:h-14 object-contain mb-3 md:mb-4"
                    />

                    <h3 class="text-[#f5f7fa] text-sm md:text-base font-medium">
                        CSS3
                    </h3>

                </div>

                <!-- JavaScript -->
                <div class="rounded-2xl border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl p-5 md:p-6 flex flex-col items-center justify-center text-center transition-all duration-300 hover:border-[#cbb190]/30 hover:-translate-y-1">

                    <img
                        src="/tech/javascript.png"
                        alt="JavaScript"
                        class="w-10 h-10 md:w-14 md:h-14 object-contain mb-3 md:mb-4"
                    />

                    <h3 class="text-[#f5f7fa] text-sm md:text-base font-medium">
                        JavaScript
                    </h3>

                </div>

                <!-- React -->
                <div class="rounded-2xl border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl p-5 md:p-6 flex flex-col items-center justify-center text-center transition-all duration-300 hover:border-[#cbb190]/30 hover:-translate-y-1">

                    <img
                        src="/tech/react.png"
                        alt="React"
                        class="w-10 h-10 md:w-14 md:h-14 object-contain mb-3 md:mb-4"
                    />

                    <h3 class="text-[#f5f7fa] text-sm md:text-base font-medium">
                        React
                    </h3>

                </div>

                <!-- Laravel -->
                <div class="rounded-2xl border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl p-5 md:p-6 flex flex-col items-center justify-center text-center transition-all duration-300 hover:border-[#cbb190]/30 hover:-translate-y-1">

                    <img
                        src="/tech/laravel.png"
                        alt="Laravel"
                        class="w-10 h-10 md:w-14 md:h-14 object-contain mb-3 md:mb-4"
                    />

                    <h3 class="text-[#f5f7fa] text-sm md:text-base font-medium">
                        Laravel
                    </h3>

                </div>

                <!-- WordPress -->
                <div class="rounded-2xl border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl p-5 md:p-6 flex flex-col items-center justify-center text-center transition-all duration-300 hover:border-[#cbb190]/30 hover:-translate-y-1">

                    <img
                        src="/tech/wordpress.png"
                        alt="WordPress"
                        class="w-10 h-10 md:w-14 md:h-14 object-contain mb-3 md:mb-4"
                    />

                    <h3 class="text-[#f5f7fa] text-sm md:text-base font-medium">
                        WordPress
                    </h3>

                </div>

                <!-- Elementor -->
                <div class="rounded-2xl border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl p-5 md:p-6 flex flex-col items-center justify-center text-center transition-all duration-300 hover:border-[#cbb190]/30 hover:-translate-y-1">

                    <img
                        src="/tech/elementor.png"
                        alt="Elementor"
                        class="w-10 h-10 md:w-14 md:h-14 object-contain mb-3 md:mb-4"
                    />

                    <h3 class="text-[#f5f7fa] text-sm md:text-base font-medium">
                        Elementor
                    </h3>

                </div>

                <!-- Photoshop -->
                <div class="rounded-2xl border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl p-5 md:p-6 flex flex-col items-center justify-center text-center transition-all duration-300 hover:border-[#cbb190]/30 hover:-translate-y-1">

                    <img
                        src="/tech/photoshop.png"
                        alt="Photoshop"
                        class="w-10 h-10 md:w-14 md:h-14 object-contain mb-3 md:mb-4"
                    />

                    <h3 class="text-[#f5f7fa] text-sm md:text-base font-medium">
                        Photoshop
                    </h3>

                </div>

            </div>

        </div>

    </div>

</section>