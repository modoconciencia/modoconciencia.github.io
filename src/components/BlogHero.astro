<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden bg-[#050505] px-6 py-20">

    <!-- Background -->
    <div class="absolute inset-0">

        <img
            src="/background-modoconciencia.jpg"
            alt="Background"
            class="w-full h-full object-cover"
        />

        <!-- Overlay oscuro -->
        <div class="absolute inset-0 bg-[#050505]/75"></div>

        <!-- Glow dorado -->
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(201,162,74,0.10),transparent_60%)]"></div>

    </div>

    <!-- Content -->
    <div class="relative z-10 text-center max-w-5xl mx-auto">

        <!-- Logo -->
        <div class="flex justify-center mb-2 md:-mb-6">

            <img
                src="/logo-cabecera.png"
                alt="Logo Modo Conciencia"
                class="w-44 md:w-72 lg:w-96 object-contain drop-shadow-[0_0_30px_rgba(241,200,91,0.30)]"
            />

        </div>

        <!-- Title -->
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black leading-none tracking-tight mb-6 md:mb-8">

            <span class="text-[#FFFFFF]">
                Modo
            </span>

            <span class="text-[#C9A24A]">
                Conciencia
            </span>

        </h1>

        <!-- Subtitle -->
        <p class="text-lg sm:text-xl md:text-2xl text-white/70 leading-relaxed max-w-3xl mx-auto mb-10 md:mb-12 px-2">

            <span class="font-semibold text-white">
                BLOG |
            </span>

            Un espacio para cuestionar la realidad.

        </p>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-5 mb-10">

            <a
                href="/"
                class="w-full sm:w-auto px-8 md:px-10 py-4 md:py-5 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md text-white font-semibold text-base md:text-lg transition-all duration-300 hover:bg-white/10 hover:border-[#C9A24A]/40 hover:scale-105"
            >
                Volver a inicio
            </a>

            <a
                href="https://www.youtube.com/@modoconcienciaoficial"
                target="_blank"
                rel="noopener noreferrer"
                class="w-full sm:w-auto px-8 md:px-10 py-4 md:py-5 rounded-2xl bg-[#C9A24A] text-[#050505] font-semibold text-base md:text-lg transition-all duration-300 hover:scale-105 hover:bg-[#F1C85B] inline-flex items-center justify-center gap-3"
            >

                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    class="w-6 h-6"
                    aria-hidden="true"
                >
                    <path d="M23.5 6.2a2.97 2.97 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A2.97 2.97 0 00.5 6.2 31.3 31.3 0 000 12a31.3 31.3 0 00.5 5.8 2.97 2.97 0 002.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a2.97 2.97 0 002.1-2.1A31.3 31.3 0 0024 12a31.3 31.3 0 00-.5-5.8zM9.75 15.5v-7l6.5 3.5-6.5 3.5z"/>
                </svg>

                <span>
                    Canal YouTube
                </span>

            </a>

        </div>

        <!-- Spotify + TikTok -->
        <div class="flex items-center justify-center gap-6 md:gap-7 flex-wrap">

            <!-- Spotify -->
            <a
                href="https://open.spotify.com/user/316klomwzc4wfwro5ptakelsmzsy"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-white/60 hover:text-[#C9A24A] transition-all duration-300 hover:scale-105 relative top-[4px]"
                aria-label="Spotify"
            >

                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    class="w-7 h-7 md:w-9 md:h-9"
                >
                    <path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm5.5 17.28a.75.75 0 01-1.03.25c-2.82-1.72-6.37-2.11-10.55-1.16a.75.75 0 11-.33-1.46c4.57-1.04 8.5-.58 11.66 1.35.35.21.47.67.25 1.02zm1.47-3.27a.94.94 0 01-1.29.31c-3.22-1.98-8.13-2.55-11.94-1.4a.94.94 0 11-.54-1.8c4.36-1.32 9.77-.68 13.46 1.58.44.27.58.85.31 1.31zm.13-3.4C15.24 8.32 8.87 8.1 5.17 9.22a1.13 1.13 0 11-.66-2.16c4.25-1.29 11.3-1.03 15.74 1.6a1.13 1.13 0 01-1.15 1.95z"/>
                </svg>

                <span class="font-semibold text-[22px] md:text-[28px] tracking-wide uppercase leading-none">
                    Spotify
                </span>

            </a>

            <!-- TikTok -->
            <a
                href="https://www.tiktok.com/@modoconciencia"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-white/60 hover:text-[#C9A24A] transition-all duration-300 hover:scale-105 relative top-[4px]"
                aria-label="TikTok"
            >

                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                    class="w-7 h-7 md:w-9 md:h-9"
                >
                    <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64c.3 0 .6.05.88.14V9.4a6.34 6.34 0 00-.88-.06A6.33 6.33 0 003.16 15.67a6.33 6.33 0 0010.82 4.47 6.27 6.27 0 001.84-4.47V8.73a8.16 8.16 0 004.77 1.52V6.81c-.34 0-.67-.04-1-.12z"/>
                </svg>

                <span class="font-semibold text-[22px] md:text-[28px] tracking-wide uppercase leading-none">
                    TikTok
                </span>

            </a>

        </div>

    </div>

</section>