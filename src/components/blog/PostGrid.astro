---
import PostCard from './PostCard.astro';

const {
    category,
    posts = [],
    currentPage = 1,
    hasPreviousPage = false,
    hasNextPage = false,
    previousUrl = '#',
    nextUrl = '#'
} = Astro.props;
---

<section class="relative z-10 px-6 pt-16 pb-24 md:pb-32 bg-[#050505]">

    <div class="max-w-5xl mx-auto">

        <!-- Title -->
        <div class="flex items-center justify-center gap-3 md:gap-4 mb-12">

            <div class="w-8 md:w-12 h-px bg-[#C9A24A]/40"></div>

            <h2 class="text-[#C9A24A] text-xl md:text-2xl font-semibold tracking-tight text-center">
                Artículos
            </h2>

            <div class="w-8 md:w-12 h-px bg-[#C9A24A]/40"></div>

        </div>

        <!-- Posts -->
        <div class="space-y-6">

            {posts.map((post) => (
                <PostCard
                    href={post.href}
                    category={category}
                    title={post.title}
                    description={post.description}
                />
            ))}

        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-center gap-6 mt-14">

            {hasPreviousPage ? (

                <a
                    href={previousUrl}
                    class="px-7 py-3 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md text-white text-sm font-medium transition-all duration-300 hover:bg-white/10 hover:border-[#C9A24A]/40 hover:text-[#C9A24A] hover:scale-105"
                >
                    Anterior
                </a>

            ) : (

                <span class="px-7 py-3 rounded-2xl border border-white/5 bg-white/[0.03] text-white/30 text-sm font-medium pointer-events-none select-none">
                    Anterior
                </span>

            )}

            <span class="text-white/90 text-lg font-semibold">
                {currentPage}
            </span>

            {hasNextPage ? (

                <a
                    href={nextUrl}
                    class="px-7 py-3 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md text-white text-sm font-medium transition-all duration-300 hover:bg-white/10 hover:border-[#C9A24A]/40 hover:text-[#C9A24A] hover:scale-105"
                >
                    Siguiente
                </a>

            ) : (

                <span class="px-7 py-3 rounded-2xl border border-white/5 bg-white/[0.03] text-white/30 text-sm font-medium pointer-events-none select-none">
                    Siguiente
                </span>

            )}

        </div>

    </div>

</section>