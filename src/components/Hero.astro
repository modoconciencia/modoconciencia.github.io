---
---

<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden bg-black px-6 py-20">

	<!-- Background -->
	<div class="absolute inset-0">

		<img
			src="/background.jpg"
			alt="Background"
			class="w-full h-full object-cover"
		/>

		<!-- Overlay oscuro -->
		<div class="absolute inset-0 bg-black/70"></div>

		<!-- Glow -->
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(203,177,144,0.10),transparent_60%)]"></div>

	</div>

	<!-- Content -->
	<div class="relative z-10 text-center max-w-5xl mx-auto">

		<!-- Logo -->
		<div class="flex justify-center mb-2 md:-mb-6">

			<img
				src="/logo.png"
				alt="Logo"
				class="w-44 md:w-72 lg:w-96 object-contain drop-shadow-[0_0_25px_rgba(203,177,144,0.25)]"
			/>

		</div>

		<!-- Title -->
		<h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black leading-none tracking-tight mb-6 md:mb-8">

			<span class="text-[#f5f7fa]">
				Juan
			</span>

			<span class="text-[#cbb190]">
				Galisteo
			</span>

		</h1>

		<!-- Subtitle -->
		<p class="text-lg sm:text-xl md:text-2xl text-[#c9d2de]/80 leading-relaxed max-w-3xl mx-auto mb-10 md:mb-12 px-2">

			Desarrollador web y diseñador de experiencias digitales

		</p>

		<!-- Buttons -->
		<div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-5 mb-10">

			<a
				href="https://github.com/juangalisteo?tab=repositories"
				target="_blank"
				class="w-full sm:w-auto px-8 md:px-10 py-4 md:py-5 rounded-2xl bg-[#cbb190] text-black font-semibold text-base md:text-lg transition-all duration-300 hover:scale-105 hover:bg-[#ddceb9]"
			>
				Ver mis proyectos
			</a>

			<a
				href="mailto:juangalisteomarques@gmail.com"
				class="w-full sm:w-auto px-8 md:px-10 py-4 md:py-5 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md text-[#f5f7fa] font-semibold text-base md:text-lg transition-all duration-300 hover:bg-white/10 hover:scale-105"
			>
				Contactar
			</a>

		</div>

		<!-- Social -->
		<div class="flex items-center justify-center gap-6 md:gap-7">

			<a
				href="https://github.com/juangalisteo"
				target="_blank"
				class="text-[#c9d2de]/70 hover:text-[#cbb190] transition-all duration-300 hover:scale-110"
				aria-label="GitHub"
			>

				<svg
					xmlns="http://www.w3.org/2000/svg"
					fill="currentColor"
					viewBox="0 0 24 24"
					class="w-7 h-7 md:w-8 md:h-8"
				>
					<path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 008 10.95c.58.1.79-.25.79-.56v-2.02c-3.25.71-3.94-1.39-3.94-1.39-.53-1.34-1.3-1.7-1.3-1.7-1.07-.73.08-.72.08-.72 1.18.08 1.8 1.21 1.8 1.21 1.05 1.8 2.76 1.28 3.43.98.1-.76.41-1.28.74-1.58-2.59-.3-5.31-1.3-5.31-5.78 0-1.28.46-2.33 1.2-3.15-.12-.3-.52-1.52.11-3.18 0 0 .98-.31 3.2 1.2a11.1 11.1 0 015.82 0c2.22-1.51 3.2-1.2 3.2-1.2.63 1.66.23 2.88.11 3.18.75.82 1.2 1.87 1.2 3.15 0 4.49-2.73 5.47-5.33 5.77.42.36.8 1.08.8 2.18v3.23c0 .31.21.67.8.56A11.5 11.5 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/>
				</svg>

			</a>

			<a
				href="https://www.linkedin.com/in/juangalisteo/"
				target="_blank"
				class="text-[#c9d2de]/70 hover:text-[#cbb190] transition-all duration-300 hover:scale-110"
				aria-label="LinkedIn"
			>

				<svg
					xmlns="http://www.w3.org/2000/svg"
					fill="currentColor"
					viewBox="0 0 24 24"
					class="w-7 h-7 md:w-8 md:h-8"
				>
					<path d="M4.98 3.5C4.98 4.88 3.86 6 2.48 6S0 4.88 0 3.5 1.12 1 2.48 1s2.5 1.12 2.5 2.5zM.5 8h4V24h-4V8zm7 0h3.84v2.16h.05c.53-1 1.84-2.16 3.79-2.16 4.05 0 4.8 2.66 4.8 6.11V24h-4v-7.11c0-1.7-.03-3.89-2.37-3.89-2.37 0-2.73 1.85-2.73 3.76V24h-4V8z"/>
				</svg>

			</a>

		</div>

	</div>

</section>