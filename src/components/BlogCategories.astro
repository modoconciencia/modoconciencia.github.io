---
---

<section class="relative z-10 px-6 pt-16 pb-20 md:pb-24 bg-[#050505]">

    <div class="max-w-7xl mx-auto">

        <!-- Title -->
        <div class="flex items-center justify-center gap-3 md:gap-4 mb-10 md:mb-14">

            <div class="w-8 md:w-12 h-px bg-[#C9A24A]/40"></div>

            <h2 class="text-[#C9A24A] text-xl md:text-2xl font-semibold tracking-tight text-center">
                Explora las categorías
            </h2>

            <div class="w-8 md:w-12 h-px bg-[#C9A24A]/40"></div>

        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

            <!-- ESPIRITUALIDAD -->
            <div class="group rounded-3xl overflow-hidden border border-white/5 bg-[#111111]/70 backdrop-blur-xl transition-all duration-300 hover:border-[#C9A24A]/20 hover:-translate-y-1">

                <div class="relative h-56 overflow-hidden">

                    <a
                        href="/blog/espiritualidad"
                        class="block w-full h-full"
                    >

                        <img
                            src="/blog/espiritualidad.jpg"
                            alt="Espiritualidad"
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                        />

                        <div class="absolute inset-0 bg-black/10"></div>

                    </a>

                </div>

                <div class="p-6 md:p-7">

                    <h3 class="text-[#f5f7fa] text-xl font-semibold mb-3">
                        ESPIRITUALIDAD
                    </h3>

                    <p class="text-[#6e7178] text-sm leading-relaxed mb-6">
                        Tradiciones, filosofía y búsqueda interior.
                    </p>

                    <a
                        href="/blog/espiritualidad"
                        class="inline-flex items-center text-[#C9A24A] text-sm font-medium transition-all duration-300 hover:text-[#F1C85B]"
                    >
                        Explorar
                    </a>

                </div>

            </div>

            <!-- SIMBOLISMO -->
            <div class="group rounded-3xl overflow-hidden border border-white/5 bg-[#111111]/70 backdrop-blur-xl transition-all duration-300 hover:border-[#C9A24A]/20 hover:-translate-y-1">

                <div class="relative h-56 overflow-hidden">

                    <a
                        href="/blog/simbolismo"
                        class="block w-full h-full"
                    >

                        <img
                            src="/blog/simbolismo.jpg"
                            alt="Simbolismo"
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                        />

                        <div class="absolute inset-0 bg-black/10"></div>

                    </a>

                </div>

                <div class="p-6 md:p-7">

                    <h3 class="text-[#f5f7fa] text-xl font-semibold mb-3">
                        SIMBOLISMO
                    </h3>

                    <p class="text-[#6e7178] text-sm leading-relaxed mb-6">
                        Arquetipos, números y significado profundo.
                    </p>

                    <a
                        href="/blog/simbolismo"
                        class="inline-flex items-center text-[#C9A24A] text-sm font-medium transition-all duration-300 hover:text-[#F1C85B]"
                    >
                        Explorar
                    </a>

                </div>

            </div>

            <!-- MASONERÍA -->
            <div class="group rounded-3xl overflow-hidden border border-white/5 bg-[#111111]/70 backdrop-blur-xl transition-all duration-300 hover:border-[#C9A24A]/20 hover:-translate-y-1">

                <div class="relative h-56 overflow-hidden">

                    <a
                        href="/blog/masoneria"
                        class="block w-full h-full"
                    >

                        <img
                            src="/blog/masoneria.jpg"
                            alt="Masonería"
                            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
                        />

                        <div class="absolute inset-0 bg-black/10"></div>

                    </a>

                </div>

                <div class="p-6 md:p-7">

                    <h3 class="text-[#f5f7fa] text-xl font-semibold mb-3">
                        MASONERÍA
                    </h3>

                    <p class="text-[#6e7178] text-sm leading-relaxed mb-6">
                        Historia, símbolos y tradición iniciática.
                    </p>

                    <a
                        href="/blog/masoneria"
                        class="inline-flex items-center text-[#C9A24A] text-sm font-medium transition-all duration-300 hover:text-[#F1C85B]"
                    >
                        Explorar
                    </a>

                </div>

            </div>

        </div>

    </div>

</section>