---
---

<footer class="relative z-10 px-6 pb-10 md:pb-14">

    <div class="max-w-7xl mx-auto">

        <div class="rounded-[32px] overflow-hidden border border-white/5 bg-[#0d1016]/70 backdrop-blur-xl">

            <!-- Main -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 px-6 md:px-14 py-5 md:py-12">

                <!-- Left -->
                <div class="max-w-2xl">

                    <!-- Small label -->
                    <div class="flex items-center gap-4 mb-8">

                        <div class="w-12 h-px bg-[#C9A24A]/40"></div>

                        <span class="text-[#C9A24A] uppercase tracking-[0.35em] text-[9px] md:text-xs">
                            Juan Galisteo
                        </span>

                    </div>

                    <!-- Title -->
                    <h2 class="text-2xl md:text-4xl font-black leading-[1.1] tracking-tight mb-6">

                        <span class="text-[#f5f7fa]">
                            Modo
                        </span>

                        <span class="text-[#C9A24A]">
                            Conciencia
                        </span>

                    </h2>

                    <!-- Text -->
                    <p class="text-[#7f848c] text-sm md:text-base leading-relaxed max-w-xl text-justify">

                        Explorando la conciencia y la realidad mediante el pensamiento, la emoción y la acción en coherencia para desarrollar una vida más consciente.

                    </p>

                </div>

                <!-- Right -->
                <div class="flex items-end justify-start lg:justify-end"></div>

            </div>

            <!-- Bottom -->
            <div class="border-t border-white/5 px-8 md:px-14 py-6 flex flex-col md:flex-row items-center justify-between gap-4">

                <p class="text-[#7f848c] text-sm text-center md:text-left">

                    © 2026 • All rights reserved

                </p>

                <div class="flex items-center gap-3 text-[#7f848c]/70 uppercase tracking-[0.20em] text-[11px]">

                    <span>Pensamiento</span>

                    <span class="text-[#cbb190]/40">•</span>

                    <span>Emoción</span>

                    <span class="text-[#cbb190]/40">•</span>

                    <span>Acción</span>

                </div>

            </div>

        </div>

    </div>

</footer>