---
import Layout from '../../../layouts/Layout.astro';

import PostHero from '../../../components/blog/PostHero.astro';
import PostGrid from '../../../components/blog/PostGrid.astro';
import Footer from '../../../components/Footer.astro';

export function getStaticPaths() {
    const allPosts = import.meta.glob('../../../content/blog/**/*.md', { eager: true });

    const categoryNames = {
        espiritualidad: 'Espiritualidad',
        simbolismo: 'Simbolismo',
        masoneria: 'Masonería',
    };

    function getCategoryFromPath(path) {
        return path.match(/content\/blog\/([^/]+)\//)?.[1];
    }

    function getSlugFromPath(path) {
        return path.split('/').pop().replace('.md', '');
    }

    const categories = [...new Set(
        Object.keys(allPosts)
            .map((path) => getCategoryFromPath(path))
            .filter(Boolean)
    )];

    return categories.map((category) => {
        const posts = Object.entries(allPosts)
            .filter(([path]) => getCategoryFromPath(path) === category)
            .map(([path, post]) => {
                const slug = post.frontmatter?.slug || getSlugFromPath(path);

                return {
                    href: `/blog/${category}/${slug}`,
                    title: post.frontmatter?.title || slug,
                    description: post.frontmatter?.description || '',
                    date: post.frontmatter?.date || '',
                };
            });

        return {
            params: { category },
            props: {
                categoryName: categoryNames[category] || category,
                posts,
            },
        };
    });
}

const { categoryName, posts } = Astro.props;
---

<Layout>

    <PostHero />

    <PostGrid
        category={categoryName}
        posts={posts}
    />

    <Footer />

</Layout>